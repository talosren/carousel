{
  "name": "carousel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Instagram carousel builder — HTML + Tailwind + vanilla JS.",
  "scripts": {
    "dev": "concurrently -k -n css,serve -c cyan,magenta \"npm:dev:css\" \"npm:serve\"",
    "dev:css": "tailwindcss -i src/styles.css -o dist/styles.css --watch",
    "build:css": "tailwindcss -i src/styles.css -o dist/styles.css --minify",
    "serve": "python3 -m http.server 4173"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "tailwindcss": "^3.4.17"
  }
}
